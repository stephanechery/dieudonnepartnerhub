# App
VITE_GEMINI_API_KEY=
VITE_GEMINI_TEXT_MODEL=gemini-2.5-flash
VITE_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Optional: Local-only fallback Google OAuth (non-Supabase mode)
VITE_GOOGLE_CLIENT_ID=

# Production auth/data backend (Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PROFILES_TABLE=partner_profiles

# Optional: force Supabase OAuth and reset links back to the Partner Hub domain.
# Production should use: https://www.dieudonnepartnerhub.org
VITE_AUTH_REDIRECT_ORIGIN=
