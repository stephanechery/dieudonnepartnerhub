# Server-only AI proxy. Set these in Vercel, not in client-side VITE variables.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
VITE_ENABLE_AI_FEATURES=true

# Optional: Local-only fallback Google OAuth (non-Supabase mode)
VITE_ENABLE_LOCAL_AUTH=false
VITE_GOOGLE_CLIENT_ID=

# Production auth/data backend (Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PROFILES_TABLE=partner_profiles
VITE_SUPABASE_ANALYTICS_TABLE=partner_analytics_events

# Recommended: force Supabase OAuth and reset links back to the Partner Hub domain.
# Production should use: https://www.dieudonnepartnerhub.org
# Never set this to dieudonnematch.org.
VITE_AUTH_REDIRECT_ORIGIN=
